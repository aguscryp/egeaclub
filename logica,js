let scene, camera, renderer, controls, vaquero;
const keys = {};
const playerConfig = JSON.parse(localStorage.getItem('playerConfig')) || { color: '#ff007f' };

function initGame() {
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x87CEEB);

    camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.set(0, 8, 15);

    renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.shadowMap.enabled = true;
    document.body.appendChild(renderer.domElement);

    scene.add(new THREE.AmbientLight(0xffffff, 0.6));
    const sun = new THREE.DirectionalLight(0xffffff, 1.0);
    sun.position.set(10, 20, 10);
    sun.castShadow = true;
    scene.add(sun);

    // Suelo
    const ground = new THREE.Mesh(new THREE.PlaneGeometry(1000, 1000), new THREE.MeshStandardMaterial({color: 0x4caf50}));
    ground.rotation.x = -Math.PI / 2;
    ground.receiveShadow = true;
    scene.add(ground);

    // Vaquero
    vaquero = new THREE.Group();
    const bodyMat = new THREE.MeshStandardMaterial({color: playerConfig.color});
    const skinMat = new THREE.MeshStandardMaterial({color: 0xffe0bd});
    
    const torso = new THREE.Mesh(new THREE.BoxGeometry(1, 1.3, 0.6), bodyMat);
    torso.position.y = 1.65;
    const head = new THREE.Mesh(new THREE.BoxGeometry(0.7, 0.7, 0.7), skinMat);
    head.position.y = 2.6;
    const hat = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.1, 1.2), new THREE.MeshStandardMaterial({color: 0x3e2723}));
    hat.position.y = 2.95;
    
    vaquero.add(torso, head, hat);
    scene.add(vaquero);

    // Controles
    controls = new THREE.OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;

    window.onkeydown = (e) => keys[e.code] = true;
    window.onkeyup = (e) => keys[e.code] = false;

    if(window.quitarCarga) window.quitarCarga();
    animate();
}

function animate() {
    requestAnimationFrame(animate);
    if(vaquero) {
        if(keys['KeyW']) vaquero.translateZ(0.2);
        if(keys['KeyS']) vaquero.translateZ(-0.2);
        if(keys['KeyA']) vaquero.rotation.y += 0.05;
        if(keys['KeyD']) vaquero.rotation.y -= 0.05;
        
        camera.position.lerp(new THREE.Vector3(0, 6, 12).applyMatrix4(vaquero.matrixWorld), 0.1);
        controls.target.lerp(vaquero.position, 0.1);
    }
    controls.update();
    renderer.render(scene, camera);
}
