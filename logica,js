/**
 * MOTOR DE ANIMACIÓN DE PERSONAJE - COWBOY ENGINE
 */

let scene, camera, renderer, controls, vaquero;
let piernaIzq, piernaDer, brazoIzquierdo, brazoDerecho;
const keys = {};

// 1. OBTENER COLOR DE PERFIL
const playerConfig = JSON.parse(localStorage.getItem('playerConfig')) || { color: '#ff007f' };

function initGame() {
    // Escena básica
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x87CEEB);

    camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.set(0, 8, 15);

    renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.shadowMap.enabled = true;
    document.body.appendChild(renderer.domElement);

    // Luces
    scene.add(new THREE.AmbientLight(0xffffff, 0.7));
    const sun = new THREE.DirectionalLight(0xffffff, 1.0);
    sun.position.set(10, 20, 10);
    scene.add(sun);

    // Suelo (Pasto)
    const ground = new THREE.Mesh(
        new THREE.PlaneGeometry(1000, 1000), 
        new THREE.MeshStandardMaterial({color: 0x4caf50})
    );
    ground.rotation.x = -Math.PI / 2;
    scene.add(ground);

    // --- CONSTRUCCIÓN DEL PERSONAJE ARTICULADO ---
    vaquero = new THREE.Group();
    const matRopa = new THREE.MeshStandardMaterial({color: playerConfig.color});
    const matPiel = new THREE.MeshStandardMaterial({color: 0xffe0bd});

    // Torso
    const torso = new THREE.Mesh(new THREE.BoxGeometry(0.8, 1.2, 0.5), matRopa);
    torso.position.y = 1.6;
    vaquero.add(torso);

    // Cabeza
    const cabeza = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.6, 0.6), matPiel);
    cabeza.position.y = 2.5;
    vaquero.add(cabeza);

    // Piernas (Separadas para animar)
    const geoExtremidad = new THREE.BoxGeometry(0.3, 0.9, 0.3);
    piernaIzq = new THREE.Mesh(geoExtremidad, matRopa);
    piernaIzq.position.set(-0.2, 0.5, 0);
    
    piernaDer = new THREE.Mesh(geoExtremidad, matRopa);
    piernaDer.position.set(0.2, 0.5, 0);

    // Brazos (Separados para animar)
    brazoIzquierdo = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.9, 0.25), matPiel);
    brazoIzquierdo.position.set(-0.55, 1.6, 0);
    
    brazoDerecho = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.9, 0.25), matPiel);
    brazoDerecho.position.set(0.55, 1.6, 0);

    vaquero.add(piernaIzq, piernaDer, brazoIzquierdo, brazoDerecho);
    scene.add(vaquero);

    // Controles
    controls = new THREE.OrbitControls(camera, renderer.domElement);
    window.onkeydown = (e) => keys[e.code] = true;
    window.onkeyup = (e) => keys[e.code] = false;

    animate();
}

function animate() {
    requestAnimationFrame(animate);
    
    let isMoving = false;
    const speed = 0.2;

    if(vaquero) {
        // Movimiento WASD
        if(keys['KeyW']) { vaquero.translateZ(speed); isMoving = true; }
        if(keys['KeyS']) { vaquero.translateZ(-speed); isMoving = true; }
        if(keys['KeyA']) { vaquero.rotation.y += 0.05; isMoving = true; }
        if(keys['KeyD']) { vaquero.rotation.y -= 0.05; isMoving = true; }

        // --- LÓGICA DE ANIMACIÓN DE EXTREMIDADES ---
        if (isMoving) {
            const time = Date.now() * 0.01; // Velocidad del paso
            const amplitude = 0.6; // Qué tanto estira la pierna

            // Movimiento alternado (Pierna izquierda adelante, brazo derecho adelante)
            piernaIzq.rotation.x = Math.sin(time) * amplitude;
            piernaDer.rotation.x = -Math.sin(time) * amplitude;
            
            brazoIzquierdo.rotation.x = -Math.sin(time) * amplitude;
            brazoDerecho.rotation.x = Math.sin(time) * amplitude;

            // Balanceo leve del cuerpo
            vaquero.position.y = Math.abs(Math.cos(time * 0.5)) * 0.1; 
        } else {
            // Volver a posición de reposo suavemente
            piernaIzq.rotation.x = 0;
            piernaDer.rotation.x = 0;
            brazoIzquierdo.rotation.x = 0;
            brazoDerecho.rotation.x = 0;
            vaquero.position.y = 0;
        }

        // Cámara sigue al personaje
        const camPos = new THREE.Vector3(0, 6, 12).applyMatrix4(vaquero.matrixWorld);
        camera.position.lerp(camPos, 0.1);
        controls.target.lerp(vaquero.position, 0.1);
    }

    controls.update();
    renderer.render(scene, camera);
}

initGame();
