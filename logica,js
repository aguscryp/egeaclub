/**
 * COWBOY ENGINE v6.0 - MUNDO LIBRE
 * Sistema preparado para inyección de objetos desde repositorio futuro.
 */

let scene, camera, renderer, controls, vaquero;
const keys = {};

// Recuperamos la personalización del localStorage (definida en perfil.html)
const playerConfig = JSON.parse(localStorage.getItem('playerConfig')) || { color: '#795548' };

function initGame() {
    // 1. ESCENA Y MOTOR
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x87CEEB); // Cielo despejado

    camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.set(0, 8, 15);

    renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.shadowMap.enabled = true;
    renderer.outputEncoding = THREE.sRGBEncoding;
    document.body.appendChild(renderer.domElement);

    // 2. ILUMINACIÓN
    scene.add(new THREE.AmbientLight(0xffffff, 0.6));
    const sun = new THREE.DirectionalLight(0xffffff, 1.2);
    sun.position.set(40, 60, 40);
    sun.castShadow = true;
    scene.add(sun);

    // 3. ENTORNO BASE (Suelo infinito)
    const ground = new THREE.Mesh(
        new THREE.PlaneGeometry(1000, 1000), 
        new THREE.MeshStandardMaterial({ color: 0x4caf50 })
    );
    ground.rotation.x = -Math.PI / 2;
    ground.receiveShadow = true;
    scene.add(ground);

    // 4. CREACIÓN DEL PERSONAJE (Basado en Perfil)
    crearVaqueroPersonalizado();

    // 5. OBJETOS DEL MAPA (Estructuras fijas)
    crearEstructurasMapa();

    // 6. CONTROLES DE CÁMARA (OrbitControls para libre giro)
    controls = new THREE.OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.1;

    // EVENTOS DE TECLADO
    window.onkeydown = (e) => { keys[e.code] = true; };
    window.onkeyup = (e) => { keys[e.code] = false; };

    // QUITAR PANTALLA DE CARGA (Ya no esperamos archivos externos pesados)
    if (typeof window.quitarCarga === "function") {
        window.quitarCarga();
    }

    animate();
}

function crearVaqueroPersonalizado() {
    vaquero = new THREE.Group();
    const matRopa = new THREE.MeshStandardMaterial({ color: playerConfig.color });
    const matPiel = new THREE.MeshStandardMaterial({ color: 0xffe0bd });
    const matSombrero = new THREE.MeshStandardMaterial({ color: 0x3e2723 });

    // Torso
    const torso = new THREE.Mesh(new THREE.BoxGeometry(1, 1.3, 0.6), matRopa);
    torso.position.y = 1.65;
    torso.castShadow = true;

    // Cabeza y Cara
    const cabeza = new THREE.Mesh(new THREE.BoxGeometry(0.7, 0.7, 0.7), matPiel);
    cabeza.position.y = 2.6;

    // Sombrero (Ala y Copa)
    const ala = new THREE.Mesh(new THREE.BoxGeometry(1.5, 0.1, 1.3), matSombrero);
    ala.position.y = 3.0;
    const copa = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.5, 0.7), matSombrero);
    copa.position.y = 3.3;

    // Piernas (Animables)
    const piernaGeo = new THREE.BoxGeometry(0.4, 1, 0.4);
    this.piernaIzq = new THREE.Mesh(piernaGeo, matRopa);
    this.piernaIzq.position.set(-0.25, 0.5, 0);
    this.piernaDer = this.piernaIzq.clone();
    this.piernaDer.position.x = 0.25;

    vaquero.add(torso, cabeza, ala, copa, this.piernaIzq, this.piernaDer);
    scene.add(vaquero);
}

function crearEstructurasMapa() {
    // Aquí puedes agregar casas o decoraciones simples de referencia
    const casa = new THREE.Group();
    const base = new THREE.Mesh(new THREE.BoxGeometry(10, 6, 10), new THREE.MeshStandardMaterial({color: 0x5d4037}));
    base.position.y = 3;
    const techo = new THREE.Mesh(new THREE.ConeGeometry(9, 5, 4), new THREE.MeshStandardMaterial({color: 0x3e2723}));
    techo.position.y = 8.5; techo.rotation.y = Math.PI/4;
    casa.add(base, techo);
    casa.position.set(-20, 0, -20);
    scene.add(casa);
}

function update() {
    if(!vaquero) return;

    let moviendo = false;
    const speed = 0.2;

    // MOVIMIENTO RELATIVO A LA ROTACIÓN
    if(keys['KeyW']) { vaquero.translateZ(speed); moviendo = true; }
    if(keys['KeyS']) { vaquero.translateZ(-speed); moviendo = true; }
    if(keys['KeyA']) { vaquero.rotation.y += 0.06; moviendo = true; }
    if(keys['KeyD']) { vaquero.rotation.y -= 0.06; moviendo = true; }

    // ANIMACIÓN SIMPLE DE CAMINATA
    if(moviendo) {
        const time = Date.now() * 0.01;
        this.piernaIzq.rotation.x = Math.sin(time) * 0.5;
        this.piernaDer.rotation.x = -Math.sin(time) * 0.5;
    } else {
        this.piernaIzq.rotation.x = 0;
        this.piernaDer.rotation.x = 0;
    }

    // CÁMARA SIGUE AL VAQUERO (Suave con LERP)
    const offset = new THREE.Vector3(0, 6, 14);
    const cameraTarget = offset.applyMatrix4(vaquero.matrixWorld);
    camera.position.lerp(cameraTarget, 0.1);
    
    controls.target.lerp(vaquero.position, 0.1);
    controls.update();
}

function animate() {
    requestAnimationFrame(animate);
    update();
    renderer.render(scene, camera);
}

// Escuchar cambios de tamaño de ventana
window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
});
