let scene, camera, renderer, controls, vaquero;
const keys = {};

// CONFIGURACIÓN DE COLOR (Con seguro por si localStorage falla)
let playerColor = "#ff007f"; 
try {
    const config = JSON.parse(localStorage.getItem('playerConfig'));
    if (config && config.color) playerColor = config.color;
} catch (e) {
    console.log("Usando color por defecto");
}

function initGame() {
    console.log("Iniciando motor 3D...");

    // 1. ESCENA
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x87CEEB); // Azul Cielo

    // 2. CÁMARA
    camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 2000);
    camera.position.set(0, 10, 20);

    // 3. RENDERER (El dibujo)
    renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.shadowMap.enabled = true;
    document.body.appendChild(renderer.domElement);

    // 4. LUCES (Si esto falta, se ve negro)
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.8);
    scene.add(ambientLight);

    const sun = new THREE.DirectionalLight(0xffffff, 1.0);
    sun.position.set(50, 100, 50);
    sun.castShadow = true;
    scene.add(sun);

    // 5. SUELO (El Pasto)
    const groundGeo = new THREE.PlaneGeometry(1000, 1000);
    const groundMat = new THREE.MeshStandardMaterial({ color: 0x4caf50 }); // Verde
    const ground = new THREE.Mesh(groundGeo, groundMat);
    ground.rotation.x = -Math.PI / 2;
    ground.receiveShadow = true;
    scene.add(ground);

    // 6. DECORACIÓN (Casa)
    crearCasa(-15, 0, -15);

    // 7. VAQUERO
    vaquero = new THREE.Group();
    const matRopa = new THREE.MeshStandardMaterial({ color: playerColor });
    const matPiel = new THREE.MeshStandardMaterial({ color: 0xffe0bd });
    
    const torso = new THREE.Mesh(new THREE.BoxGeometry(1, 1.3, 0.6), matRopa);
    torso.position.y = 1.65;
    
    const cabeza = new THREE.Mesh(new THREE.BoxGeometry(0.7, 0.7, 0.7), matPiel);
    cabeza.position.y = 2.6;

    vaquero.add(torso, cabeza);
    scene.add(vaquero);

    // 8. CONTROLES
    controls = new THREE.OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;

    window.onkeydown = (e) => { keys[e.code] = true; };
    window.onkeyup = (e) => { keys[e.code] = false; };

    animate();
}

function crearCasa(x, y, z) {
    const casa = new THREE.Group();
    const walls = new THREE.Mesh(new THREE.BoxGeometry(8, 5, 8), new THREE.MeshStandardMaterial({color: 0x5d4037}));
    walls.position.y = 2.5;
    const roof = new THREE.Mesh(new THREE.ConeGeometry(7, 4, 4), new THREE.MeshStandardMaterial({color: 0x3e2723}));
    roof.position.y = 6.5; roof.rotation.y = Math.PI/4;
    casa.add(walls, roof);
    casa.position.set(x, y, z);
    scene.add(casa);
}

function animate() {
    requestAnimationFrame(animate);
    
    if(vaquero) {
        const speed = 0.2;
        if(keys['KeyW']) vaquero.translateZ(speed);
        if(keys['KeyS']) vaquero.translateZ(-speed);
        if(keys['KeyA']) vaquero.rotation.y += 0.05;
        if(keys['KeyD']) vaquero.rotation.y -= 0.05;

        // Cámara suave
        const relativeOffset = new THREE.Vector3(0, 6, 12);
        const camOffset = relativeOffset.applyMatrix4(vaquero.matrixWorld);
        camera.position.lerp(camOffset, 0.1);
        controls.target.lerp(vaquero.position, 0.1);
    }

    controls.update();
    renderer.render(scene, camera);
}

// Rescate por si la ventana cambia
window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
});
