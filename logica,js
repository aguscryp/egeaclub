let scene, camera, renderer, controls, vaquero, sw4;
let isDriving = false;
const keys = {};

// Colores del perfil
const playerConfig = JSON.parse(localStorage.getItem('playerConfig')) || { color: '#795548' };

function initGame() {
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x87CEEB);

    camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.set(0, 10, 20);

    renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.shadowMap.enabled = true;
    renderer.outputEncoding = THREE.sRGBEncoding;
    document.body.appendChild(renderer.domElement);

    // Luces profesionales
    scene.add(new THREE.AmbientLight(0xffffff, 0.6));
    const sun = new THREE.DirectionalLight(0xffffff, 1.2);
    sun.position.set(40, 60, 40);
    sun.castShadow = true;
    scene.add(sun);

    // Suelo infinito
    const ground = new THREE.Mesh(
        new THREE.PlaneGeometry(1000, 1000), 
        new THREE.MeshStandardMaterial({ color: 0x4caf50 })
    );
    ground.rotation.x = -Math.PI / 2;
    ground.receiveShadow = true;
    scene.add(ground);

    // Construcción del Mapa (Cosas que todos ven)
    crearEntorno();
    crearVaqueroPersonalizado();
    
    // Carga de la SW4 Realista
    const loader = new THREE.GLTFLoader();
    loader.load('https://raw.githubusercontent.com/KhronosGroup/glTF-Sample-Models/master/2.0/CesiumMilkTruck/glTF-Binary/CesiumMilkTruck.glb', (gltf) => {
        sw4 = gltf.scene;
        sw4.position.set(10, 0, 5);
        sw4.scale.set(2.5, 2.5, 2.5);
        sw4.traverse(n => { if(n.isMesh) n.castShadow = true; });
        scene.add(sw4);
        
        // ¡MUNDO LISTO! Quitamos la pantalla de carga
        if (typeof quitarCarga === "function") quitarCarga();
    });

    controls = new THREE.OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;

    window.onkeydown = (e) => { 
        keys[e.code] = true; 
        if(e.code === 'KeyE') intentarSubir();
    };
    window.onkeyup = (e) => keys[e.code] = false;

    animate();
}

function crearEntorno() {
    // Casa rústica
    const casa = new THREE.Group();
    const walls = new THREE.Mesh(new THREE.BoxGeometry(10, 6, 10), new THREE.MeshStandardMaterial({color: 0x5d4037}));
    walls.position.y = 3;
    const roof = new THREE.Mesh(new THREE.ConeGeometry(9, 5, 4), new THREE.MeshStandardMaterial({color: 0x3e2723}));
    roof.position.y = 8.5; roof.rotation.y = Math.PI/4;
    casa.add(walls, roof);
    casa.position.set(-15, 0, -10);
    scene.add(casa);
}

function crearVaqueroPersonalizado() {
    vaquero = new THREE.Group();
    const matRopa = new THREE.MeshStandardMaterial({ color: playerConfig.color });
    const matPiel = new THREE.MeshStandardMaterial({ color: 0xffe0bd });

    const torso = new THREE.Mesh(new THREE.BoxGeometry(1, 1.3, 0.6), matRopa);
    torso.position.y = 1.65;
    const cabeza = new THREE.Mesh(new THREE.BoxGeometry(0.7, 0.7, 0.7), matPiel);
    cabeza.position.y = 2.6;
    
    // Sombrero Cowboy
    const ala = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.1, 1.2), new THREE.MeshStandardMaterial({color: 0x3e2723}));
    ala.position.y = 2.95;
    vaquero.add(torso, cabeza, ala);
    scene.add(vaquero);
}

function intentarSubir() {
    if(!sw4) return;
    const dist = vaquero.position.distanceTo(sw4.position);
    if(!isDriving && dist < 6) {
        isDriving = true;
        vaquero.visible = false;
    } else if(isDriving) {
        isDriving = false;
        vaquero.visible = true;
        vaquero.position.copy(sw4.position).add(new THREE.Vector3(4,0,0));
    }
}

function update() {
    const target = isDriving ? sw4 : vaquero;
    if(!target) return;

    if(!isDriving) {
        if(keys['KeyW']) vaquero.translateZ(0.2);
        if(keys['KeyS']) vaquero.translateZ(-0.2);
        if(keys['KeyA']) vaquero.rotation.y += 0.06;
        if(keys['KeyD']) vaquero.rotation.y -= 0.06;
    } else {
        if(keys['KeyW']) sw4.translateZ(0.5);
        if(keys['KeyS']) sw4.translateZ(-0.2);
        if(keys['KeyA']) sw4.rotation.y += 0.04;
        if(keys['KeyD']) sw4.rotation.y -= 0.04;
    }

    // Cámara dinámica PRO
    const offset = isDriving ? new THREE.Vector3(0, 8, 18) : new THREE.Vector3(0, 5, 12);
    const cameraTarget = offset.applyMatrix4(target.matrixWorld);
    camera.position.lerp(cameraTarget, 0.1);
    controls.target.lerp(target.position, 0.1);
    controls.update();
}

function animate() {
    requestAnimationFrame(animate);
    update();
    renderer.render(scene, camera);
}
